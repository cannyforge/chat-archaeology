# Discord bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=you-discord-channel-id-here

# LLM (Anthropic or any compatible API)
LLM_API_KEY=sk-...
LLM_MODEL=claude-sonnet-4-6
LLM_FAST_MODEL=claude-haiku-4-5-20251001
